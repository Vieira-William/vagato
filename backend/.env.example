# Banco de dados
DATABASE_URL=sqlite:///./data/vagas.db

# Para produção com PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/vagas_db

# LinkedIn (para scrapers)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/callback

# ── Observabilidade (PRD v7) ──
# Sentry: criar projeto "vagas-backend" em https://sentry.io → Settings → Client Keys (DSN)
SENTRY_DSN=https://xxxxx@o123456.ingest.sentry.io/backend-id
# Token para upload de source maps (Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Ambiente: "development" | "production"
ENVIRONMENT=development
APP_VERSION=0.1.0
