# =============================================================================
# VAGATO BACKEND — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no Git.
# Em produção (Render), configure todas as vars pelo painel Dashboard → Environment.
# =============================================================================

# ── Banco de dados ────────────────────────────────────────────────────────────
# SQLite local (dev rápido):
DATABASE_URL=sqlite:///./data/vagas.db
# PostgreSQL Neon (recomendado para dev/prod):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Auth ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SUPABASE_JWT_SECRET=  # opcional — fallback HS256 para tokens legados

# ── JWT Internos (OBRIGATÓRIO em produção) ────────────────────────────────────
# Gerar com: python -c "import secrets; print(secrets.token_hex(64))"
EXTENSION_JWT_SECRET=gere-um-secret-seguro-aqui
ADMIN_JWT_SECRET=gere-um-secret-seguro-aqui

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/callback
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback
GOOGLE_TASKS_REDIRECT_URI=http://localhost:8000/api/google-tasks/callback

# ── LinkedIn OAuth2 ───────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=xxxxxxxxxxxxxx
LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/linkedin/callback

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+14155238886
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Observabilidade (Sentry) ──────────────────────────────────────────────────
SENTRY_DSN=https://xxxxx@o123456.ingest.sentry.io/xxxxxxx
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ENVIRONMENT=development
APP_VERSION=0.1.0

# ── CORS extra (opcional) ─────────────────────────────────────────────────────
# Lista de origens extras separadas por vírgula — para IPs de rede local em dev.
# Exemplo: EXTRA_CORS_ORIGINS=http://192.168.1.22:5173,http://192.168.1.16:5173
EXTRA_CORS_ORIGINS=
